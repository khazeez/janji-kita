# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# App
NEXT_PUBLIC_JANJIKITA_URL=https://your-domain.art
EMAIL=your-email@domain.com

# Cloudflare R2
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET=customer-photos
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
S3_API=https://xxxx.r2.cloudflarestorage.com

# Midtrans
NEXT_PUBLIC_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-xxxx
MIDTRANS_CLIENT_KEY=Mid-client-xxxx
MIDTRANS_SERVER_KEY=Mid-server-xxxx

# Cloudflare (for API)
CLOUDFLARE_API_TOKEN=your_cf_api_token

# Database
PASSWORD_DB_SUPABASE=your_db_password
